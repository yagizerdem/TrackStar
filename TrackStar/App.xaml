<Application x:Class="TrackStar.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TrackStar"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="Border" x:Key="DarkBlueGradientStyle">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="#003366" />
                        <!-- Deep blue -->
                        <GradientStop Offset="0.5" Color="#00509E" />
                        <!-- Medium blue -->
                        <GradientStop Offset="1.0" Color="#003366" />
                        <!-- Lighter blue -->
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Border" x:Key="BlackGradientStyle">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="#000000" />
                        <!-- Pure black -->
                        <GradientStop Offset="0.5" Color="#2B2B2B" />
                        <!-- Dark gray -->
                        <GradientStop Offset="1.0" Color="#000000" />
                        <!-- Medium gray -->
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="LeftBarNavigationButtons">
            <Setter Property="BorderThickness" >
                <Setter.Value>0</Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <!-- Foreground (text) remains visible -->
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>




    </Application.Resources>
</Application>
